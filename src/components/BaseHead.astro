---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import ThemeScript from './ThemeScript.astro';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-about.png';
import profilePic from '../assets/profile.jpg';
import { getSite } from '../utils/consts';
import { SEO } from 'astro-seo';

const site = await getSite();

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
	type?: 'website' | 'article';
	pubDate?: Date;
	updatedDate?: Date;
	tags?: string[];
	noindex?: boolean;
	videoUrl?: string;
}

const {
	title,
	description,
	image = FallbackImage,
	type = 'website',
	pubDate,
	updatedDate,
	tags = [],
	noindex = false,
	videoUrl,
} = Astro.props;

const siteName = site.author?.name || site.title || 'Rich Kuo';
const twitterHandle = '@richkuo7';
const LANG = 'en-US';

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const videoId = videoUrl?.match(/(?:youtu\.be\/|[?&]v=|\/embed\/)([\w-]{11})/)?.[1];

const img = image as ImageMetadata;
const imageURL = videoId
	? new URL(`https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`)
	: new URL(img.src, Astro.site ?? Astro.url);
const imageWidth = videoId ? 1280 : img.width;
const imageHeight = videoId ? 720 : img.height;

const publishedISO = pubDate?.toISOString();
const modifiedISO = (updatedDate ?? pubDate)?.toISOString();

const authorPerson = {
	'@type': 'Person',
	'@id': new URL('/#person', Astro.site ?? Astro.url).toString(),
	name: siteName,
	url: Astro.site?.toString(),
	image: new URL(profilePic.src, Astro.site ?? Astro.url).toString(),
	jobTitle: site.author?.role,
	description: site.author?.bio,
	knowsAbout: site.author?.knowsAbout,
	sameAs: (site.social ?? []).map((s: { href: string }) => s.href),
};

const websiteJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: site.title,
	description: site.description,
	url: Astro.site?.toString(),
	inLanguage: LANG,
};

const articleJsonLd =
	type === 'article'
		? {
				'@context': 'https://schema.org',
				'@type': 'Article',
				headline: title,
				description,
				datePublished: publishedISO,
				dateModified: modifiedISO,
				keywords: tags.length ? tags.join(', ') : undefined,
				inLanguage: LANG,
				author: authorPerson,
				publisher: authorPerson,
				image: imageURL.toString(),
				url: canonicalURL.toString(),
				mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL.toString() },
			}
		: null;

const videoJsonLd = videoId
	? {
			'@context': 'https://schema.org',
			'@type': 'VideoObject',
			name: title,
			description,
			thumbnailUrl: imageURL.toString(),
			uploadDate: publishedISO,
			contentUrl: videoUrl,
			embedUrl: `https://www.youtube-nocookie.com/embed/${videoId}`,
			publisher: authorPerson,
		}
	: null;

// Breadcrumbs for article pages: Home > Section > Title
const segments = canonicalURL.pathname.split('/').filter(Boolean);
const breadcrumbJsonLd =
	type === 'article' && segments.length > 1
		? {
				'@context': 'https://schema.org',
				'@type': 'BreadcrumbList',
				itemListElement: [
					{ '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).toString() },
					{
						'@type': 'ListItem',
						position: 2,
						name: segments[0].charAt(0).toUpperCase() + segments[0].slice(1),
						item: new URL(`/${segments[0]}/`, Astro.site).toString(),
					},
					{ '@type': 'ListItem', position: 3, name: title, item: canonicalURL.toString() },
				],
			}
		: null;
---

<SEO
	charset="utf-8"
	title={title}
	titleTemplate={type === 'article' ? `%s · ${siteName}` : undefined}
	description={description}
	canonical={canonicalURL.toString()}
	noindex={noindex}
	nofollow={noindex}
	robotsExtras="max-image-preview:large, max-snippet:-1, max-video-preview:-1"
	openGraph={{
		basic: {
			title,
			type,
			image: imageURL.toString(),
			url: canonicalURL.toString(),
		},
		optional: {
			description,
			siteName,
			locale: 'en_US',
		},
		image: {
			url: imageURL.toString(),
			width: imageWidth,
			height: imageHeight,
			alt: title,
		},
		...(type === 'article'
			? {
					article: {
						publishedTime: publishedISO,
						modifiedTime: modifiedISO,
						authors: [siteName],
						tags,
					},
				}
			: {}),
	}}
	twitter={{
		card: 'summary_large_image',
		site: twitterHandle,
		creator: twitterHandle,
		title,
		description,
		image: imageURL.toString(),
		imageAlt: title,
	}}
	extend={{
		link: [
			{ rel: 'icon', type: 'image/svg+xml', href: '/favicon.svg' },
			{ rel: 'sitemap', href: '/sitemap-index.xml' },
			{ rel: 'alternate', type: 'application/rss+xml', title: site.title, href: new URL('rss.xml', Astro.site).toString() },
		],
		meta: [
			{ name: 'viewport', content: 'width=device-width,initial-scale=1' },
			{ name: 'generator', content: Astro.generator },
			{ name: 'author', content: siteName },
		],
	}}
/>

<ThemeScript />

<script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />
{articleJsonLd && <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />}
{breadcrumbJsonLd && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />}
{videoJsonLd && <script type="application/ld+json" set:html={JSON.stringify(videoJsonLd)} />}
