---
interface Action {
  label: string;
  href: string;
  icon?: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  actions?: Action[];
  role?: string;
  location?: string;
}

import { withBase } from "../utils/slugify";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import profilePic from "../assets/profile.jpg";

const isExternal = (path: string) => /^[a-z][a-z0-9+.-]*:/i.test(path) || path.startsWith('//');

const { title, description, actions = [], role, location } = Astro.props as Props;
---

<section class="flex flex-col">
  <div class="flex items-start gap-6 px-8 pb-4" style="align-items: flex-start;">
    <!-- Profile image: sits to the left, aligned with message section -->
    <Image
      src={profilePic}
      alt="Rich Kuo"
      width={400}
      height={400}
      class="rounded-full object-cover shrink-0 w-20 md:w-32"
    />

    <!-- Right column: title, icons, messages all aligned -->
    <div class="flex flex-col gap-3 flex-1 max-w-md">
      <div
        class="hero-letters text-[6vw] md:text-[5rem] lg:text-[5rem] leading-[0.85] font-extrabold text-base-900"
        aria-hidden="true"
      >
        {title}
      </div>

      {actions.length > 0 && (
        <div class="flex flex-row justify-between w-full">
          {actions.map((action) => (
            isExternal(action.href) ? (
              <a
                class="text-base-900 hover:text-base-500 inline-flex items-center"
                href={action.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={action.label}
              >
                {action.icon ? <Icon name={action.icon} size={50} /> : action.label}
              </a>
            ) : (
              <a
                class="text-base-900 hover:text-base-500 inline-flex items-center"
                href={withBase(action.href)}
                aria-label={action.label}
              >
                {action.icon ? <Icon name={action.icon} size={50} /> : action.label}
              </a>
            )
          ))}
        </div>
      )}

      <slot />
    </div>
  </div>

  <div class="border-b border-base-200"></div>
</section>
