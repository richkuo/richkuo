---
interface Action {
  label: string;
  href: string;
  icon?: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  actions?: Action[];
  role?: string;
  location?: string;
}

import { withBase } from "../utils/slugify";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import profilePic from "../assets/profile.jpg";

const isExternal = (path: string) => /^[a-z][a-z0-9+.-]*:/i.test(path) || path.startsWith('//');

const { title, description, actions = [], role, location } = Astro.props as Props;

const letterColors = [
  '#ef4444', // red
  '#f97316', // orange
  '#eab308', // yellow
  '#22c55e', // green
  '#06b6d4', // cyan
  '#3b82f6', // blue
  '#6366f1', // indigo
  '#7c3aed', // violet
  '#a855f7', // purple
  '#000000', // black
];

const letters = title.split('').map((char: string, i: number) => ({
  char,
  color: char.trim() === '' ? 'transparent' : letterColors[i % letterColors.length],
}));
---

<section class="flex flex-col">
  <div class="flex items-center gap-6 px-3 sm:px-5 md:px-8 pb-4">
    <!-- Profile image: sits to the left, aligned with message section -->
    <Image
      src={profilePic}
      alt="Rich Kuo"
      width={400}
      height={400}
      class="rounded-full object-cover shrink-0 w-20 md:w-32"
    />

    <!-- Right column: title, icons (md+), messages -->
    <div class="flex flex-col gap-3 flex-1 max-w-md">
      <div
        class="hero-letters shimmer-text text-[13vw] sm:text-[10vw] md:text-[5rem] lg:text-[5rem] leading-[0.85] font-extrabold"
        aria-hidden="true"
      >
        {letters.map(({ char, color }: { char: string; color: string }) => (
          <span style={`color: ${color}`}>{char}</span>
        ))}
      </div>

      {actions.length > 0 && (
        <div class="hero-social-icons hidden md:flex flex-row justify-between w-full">
          {actions.map((action) => (
            isExternal(action.href) ? (
              <a
                class="inline-flex items-center"
                href={action.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={action.label}
              >
                {action.icon ? <Icon name={action.icon} size={50} /> : action.label}
              </a>
            ) : (
              <a
                class="inline-flex items-center"
                href={withBase(action.href)}
                aria-label={action.label}
              >
                {action.icon ? <Icon name={action.icon} size={50} /> : action.label}
              </a>
            )
          ))}
        </div>
      )}

      <slot />
    </div>
  </div>

  {actions.length > 0 && (
    <div class="hero-social-icons md:hidden flex flex-row justify-between w-full pb-4">
      {actions.map((action) => (
        isExternal(action.href) ? (
          <a
            class="inline-flex items-center"
            href={action.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={action.label}
          >
            {action.icon ? <Icon name={action.icon} size={50} /> : action.label}
          </a>
        ) : (
          <a
            class="inline-flex items-center"
            href={withBase(action.href)}
            aria-label={action.label}
          >
            {action.icon ? <Icon name={action.icon} size={50} /> : action.label}
          </a>
        )
      ))}
    </div>
  )}

  <div class="border-b border-base-200"></div>
</section>

<script>
  const totalDuration = 15; // seconds per cycle
  const holdDuration = 5;   // seconds to pause at end of sweep
  const sweepPct = ((totalDuration - holdDuration) / totalDuration) * 100;

  const palette = ['#ef4444','#f97316','#eab308','#22c55e','#06b6d4','#3b82f6','#6366f1','#7c3aed','#a855f7','#000000'];
  // Fisher-Yates shuffle
  for (let i = palette.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [palette[i], palette[j]] = [palette[j], palette[i]];
  }

  // Inject text-shimmer keyframes and apply animation
  const shimmer = document.querySelector('.hero-letters') as HTMLElement | null;
  if (shimmer) {
    shimmer.style.setProperty('--shimmer-gradient', `linear-gradient(90deg, ${[...palette, palette[0]].join(',')})`);
    const spans = shimmer.querySelectorAll('span');
    spans.forEach((span, i) => {
      const color = palette[i % palette.length];
      (span as HTMLElement).style.color = color;
    });
    const textStyleEl = document.createElement('style');
    textStyleEl.textContent = `@keyframes text-shimmer {
      0%        { background-position: 200% center; }
      ${sweepPct.toFixed(1)}% { background-position: 0% center; }
      100%      { background-position: 0% center; }
    }`;
    document.head.appendChild(textStyleEl);
    shimmer.style.animation = `text-shimmer ${totalDuration}s linear infinite`;
  }

  // Shimmer social icons with staggered color-cycling animation
  const iconEls = document.querySelectorAll('.hero-social-icons a');
  if (iconEls.length > 0) {
    const stops = palette.map((color, i) => {
      const pct = (i / palette.length * sweepPct).toFixed(2);
      return `${pct}% { color: ${color}; }`;
    });
    stops.push(`${sweepPct.toFixed(1)}% { color: ${palette[0]}; }`);
    stops.push(`100% { color: ${palette[0]}; }`);
    const iconStyleEl = document.createElement('style');
    iconStyleEl.textContent = `@keyframes icon-shimmer { ${stops.join(' ')} }`;
    document.head.appendChild(iconStyleEl);

    // Stagger across the sweep window only (not the hold portion)
    const sweepDuration = totalDuration * (sweepPct / 100);
    const stagger = sweepDuration / iconEls.length;
    iconEls.forEach((el, i) => {
      const htmlEl = el as HTMLElement;
      htmlEl.style.animation = `icon-shimmer ${totalDuration}s linear infinite reverse`;
      htmlEl.style.animationDelay = `${-(i * stagger)}s`;
    });
  }
</script>
