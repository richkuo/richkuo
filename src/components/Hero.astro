---
interface Action {
  label: string;
  href: string;
  icon?: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  actions?: Action[];
  role?: string;
  location?: string;
}

import { withBase } from "../utils/slugify";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import profilePic from "../assets/profile.jpg";

const isExternal = (path: string) => /^[a-z][a-z0-9+.-]*:/i.test(path) || path.startsWith('//');

const { title, description, actions = [], role, location } = Astro.props as Props;

const palette = ['#ef4444','#f97316','#eab308','#22c55e','#06b6d4','#3b82f6','#6366f1','#7c3aed','#a855f7','#000000'];

const letters = title.split('').map((char: string, i: number) => ({
  char,
  color: char.trim() === '' ? 'transparent' : palette[i % palette.length],
}));
---

<section class="flex flex-col" data-palette={JSON.stringify(palette)}>
  <div class="flex items-center gap-6 px-3 sm:px-5 md:px-8 pb-4">
    <!-- Profile image: sits to the left, aligned with message section -->
    <Image
      src={profilePic}
      alt="Rich Kuo"
      width={400}
      height={400}
      class="rounded-full object-cover shrink-0 w-20 md:w-32"
    />

    <!-- Right column: title, messages -->
    <div class="flex flex-col gap-3 flex-1 max-w-md">
      <div
        class="hero-letters shimmer-text text-[13vw] sm:text-[10vw] md:text-[5rem] lg:text-[5rem] leading-[0.85] font-extrabold"
        aria-hidden="true"
      >
        {letters.map(({ char, color }: { char: string; color: string }) => (
          <span style={`color: ${color}`}>{char}</span>
        ))}
      </div>

      <slot />
    </div>
  </div>

  {actions.length > 0 && (
    <div class="hero-social-icons flex flex-row justify-between w-full px-3 sm:px-5 md:px-8 pb-4">
      {actions.map((action) => (
        isExternal(action.href) ? (
          <a
            class="inline-flex items-center"
            href={action.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={action.label}
          >
            {action.icon ? <Icon name={action.icon} size={50} /> : action.label}
          </a>
        ) : (
          <a
            class="inline-flex items-center"
            href={withBase(action.href)}
            aria-label={action.label}
          >
            {action.icon ? <Icon name={action.icon} size={50} /> : action.label}
          </a>
        )
      ))}
    </div>
  )}

  <div id="discord-copy-row" class="hidden px-3 sm:px-5 md:px-8 pb-4 flex items-center gap-3">
    <span class="text-sm text-base-content/70">Viewing from TikTok? Click here to copy the link and paste it into your regular web browser</span>
    <button
      id="discord-copy-btn"
      class="shrink-0 inline-flex items-center justify-center gap-2 px-4 py-2 rounded-xl bg-[#5865F2] text-white font-semibold text-sm transition hover:bg-[#4752c4] active:scale-[0.98] cursor-pointer"
      data-link="https://discord.gg/44BykmWZsP"
    >
      <Icon name="tabler:brand-discord" size={18} />
      <span>Copy Invite</span>
    </button>
  </div>

  <div class="border-b border-base-200"></div>
</section>

<script>
  const totalDuration = 15; // seconds per cycle
  const holdDuration = 5;   // seconds to pause at end of sweep
  const sweepPct = ((totalDuration - holdDuration) / totalDuration) * 100;

  const paletteEl = document.querySelector('section[data-palette]');
  const palette: string[] = paletteEl ? JSON.parse(paletteEl.getAttribute('data-palette')!) : [];
  // Fisher-Yates shuffle
  for (let i = palette.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [palette[i], palette[j]] = [palette[j], palette[i]];
  }

  // Inject keyframes for both text-shimmer and icon-shimmer
  const iconStops = palette.map((color, i) => {
    const pct = (i / palette.length * sweepPct).toFixed(2);
    return `${pct}% { color: ${color}; }`;
  });
  iconStops.push(`${sweepPct.toFixed(1)}% { color: ${palette[0]}; }`);
  iconStops.push(`100% { color: ${palette[0]}; }`);
  const styleEl = document.createElement('style');
  styleEl.textContent = `
    @keyframes text-shimmer {
      0%        { background-position: 200% center; }
      ${sweepPct.toFixed(1)}% { background-position: 0% center; }
      100%      { background-position: 0% center; }
    }
    @keyframes icon-shimmer { ${iconStops.join(' ')} }
  `;
  document.head.appendChild(styleEl);

  // Apply text shimmer animation
  const shimmer = document.querySelector('.hero-letters') as HTMLElement | null;
  if (shimmer) {
    shimmer.style.setProperty('--shimmer-gradient', `linear-gradient(90deg, ${[...palette, palette[0]].join(',')})`);
    shimmer.querySelectorAll('span').forEach((span, i) => {
      (span as HTMLElement).style.color = palette[i % palette.length];
    });
    shimmer.style.animation = `text-shimmer ${totalDuration}s linear infinite`;
  }

  // Apply icon shimmer animation with staggered delays
  const iconEls = document.querySelectorAll('.hero-social-icons a');
  if (iconEls.length > 0) {
    const stagger = (totalDuration * sweepPct / 100) / iconEls.length;
    iconEls.forEach((el, i) => {
      const htmlEl = el as HTMLElement;
      htmlEl.style.animation = `icon-shimmer ${totalDuration}s linear infinite reverse`;
      htmlEl.style.animationDelay = `${-(i * stagger)}s`;
    });
  }

  // Show Discord copy row for TikTok visitors
  const params = new URLSearchParams(window.location.search);
  if (params.get('source') === 'tt') {
    const row = document.getElementById('discord-copy-row');
    if (row) row.classList.remove('hidden');
  }

  const copyBtn = document.getElementById('discord-copy-btn');
  if (copyBtn) {
    copyBtn.addEventListener('click', () => {
      const link = copyBtn.getAttribute('data-link')!;
      navigator.clipboard.writeText(link).then(() => {
        const span = copyBtn.querySelector('span');
        if (span) {
          span.textContent = 'Copied!';
          setTimeout(() => { span.textContent = 'Copy Invite'; }, 2000);
        }
      });
    });
  }
</script>
