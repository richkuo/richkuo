---
// Theme toggle button; preference logic lives in ThemeScript.astro (BaseHead)
export interface Props {
  class?: string;
}
import { Icon } from "astro-icon/components";
const { class: className = '' } = Astro.props as Props;
---

<button
	type="button"
	data-theme-toggle
	aria-label="Toggle theme"
	class={className}
>
	<span class="sr-only">Toggle theme</span>
	<span class="theme-toggle__icon inline-flex [html[data-theme='dark']_&]:hidden" aria-hidden="true">
		<Icon name="tabler:moon" size={22} />
	</span>
	<span class="theme-toggle__icon hidden [html[data-theme='dark']_&]:inline-flex" aria-hidden="true">
		<Icon name="tabler:sun" size={22} />
	</span>
</button>
