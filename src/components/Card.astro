---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import FormattedDate from './FormattedDate.astro';

interface Props {
	title: string;
	href: string;
	readMoreHref?: string;
	description?: string;
	date?: Date | string;
	image?: ImageMetadata | string;
	imageAlt?: string;
	eyebrow?: string;
}

const { title, href, readMoreHref, description, date, image, imageAlt = '', eyebrow } = Astro.props as Props;

const baseDate = typeof date === 'string' ? new Date(date) : date;

const articleClass = 'group relative grid grid-cols-1 gap-4 lg:grid-cols-3 lg:items-start p-5 rounded-[28px] border-[5px] border-transparent bg-[color:var(--color-surface)] shadow-none transition duration-200 hover:-translate-y-[2px] hover:border-black hover:shadow-[0_18px_45px_color-mix(in_oklab,var(--color-ink)_25%,transparent)] focus-within:-translate-y-1 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-border';

const isExternal = /^https?:\/\//.test(href) || href.startsWith('//');
---

<article class={articleClass}>

	<!-- Stretched link covering the whole card -->
	<a
		class="absolute inset-0 z-0 rounded-[28px]"
		href={href}
		aria-label={title}
		{...(isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
	></a>

	{image && (
		<figure class="lg:col-span-full relative overflow-hidden bg-[color-mix(in_oklab,var(--color-ink)_4%,var(--color-surface))]">
			{typeof image === 'string' ? (
				<img
					src={image}
					alt={imageAlt}
					loading="lazy"
					class="lg:col-span-full aspect-12/7 object-cover object-top w-full transition duration-400 group-hover:scale-[1.02]"
				/>
			) : (
				<Image
					src={image}
					alt={imageAlt}
					loading="lazy"
					class="lg:col-span-full aspect-12/7 object-cover object-top w-full transition duration-400 group-hover:scale-[1.02]"
				/>
			)}
		</figure>
	)}

	<div class="relative z-10 lg:col-span-2">
		{eyebrow && <p class="text-[0.65rem] font-semibold uppercase tracking-[0.2em] text-[color:var(--color-accent)]">{eyebrow}</p>}
		<h3 class="text-sm 2xl:text-xl text-[color:var(--color-primary)] font-bold uppercase">{title}</h3>
		{description && <p class="text-xs 2xl:text-lg mt-1 text-[color-mix(in_srgb,var(--color-primary)_70%,var(--color-text-light)_30%)]">{description}</p>}
	</div>

	{baseDate && (
		<p class="relative z-10 text-xs 2xl:text-lg text-base-600 lg:ml-auto">
			<time datetime={baseDate.toISOString()}>
				<FormattedDate date={baseDate} />
			</time>
		</p>
	)}

	{readMoreHref && (
		<div class="relative z-10 mt-2 lg:col-span-full">
			<a href={readMoreHref} class="text-xs font-bold uppercase hover:underline">Read more →</a>
		</div>
	)}

	<div class="relative z-10 mt-2 lg:col-span-full mt-auto pt-2 text-[0.95rem] text-[color-mix(in_srgb,var(--color-primary)_70%,var(--color-text-light)_30%)]">
		<slot />
	</div>
</article>
