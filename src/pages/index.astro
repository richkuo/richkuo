---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { getSite } from '../utils/consts';
import { withBase } from '../utils/slugify';
import { Icon } from 'astro-icon/components';

const site = await getSite();
const allProjects = (await getCollection('projects')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const projects = allProjects.filter((p) => !p.data.friend);
const friendProjects = allProjects.filter((p) => p.data.friend);
---

<PageLayout
	title={site.author.name || 'Dasein'}
>
	<Hero
		title={site.author.name || 'Dasein'}
		actions={site.social.map((s: { id: string; label: string; href: string }) => ({
			label: s.label,
			href: s.href,
			icon: {
				github: 'tabler:brand-github',
				x: 'tabler:brand-x',
				linkedin: 'tabler:brand-linkedin',
				tiktok: 'tabler:brand-tiktok',
				instagram: 'tabler:brand-instagram',
				youtube: 'tabler:brand-youtube',
				discord: 'tabler:brand-discord',
				email: 'tabler:mail',
			}[s.id],
		}))}
	>
	</Hero>

	<div class="content-shell py-6">
		<div class="flex justify-start"><p class="text-lg px-4 py-3 rounded-2xl font-serif rounded-bl-none bg-gray-200 text-gray-900">Its time for your next adventure</p></div>
	</div>

	<section class="content-shell py-6 space-y-6">
		<h2 class="text-sm font-bold uppercase tracking-widest text-base-900">Current Projects</h2>
		{projects.length === 0 ? (
			<p class="text-muted">No projects published yet.</p>
		) : (
			<div class="space-y-6">
				{projects.map((project) => (
					<a
						class="group block w-full overflow-hidden rounded-[28px] border-[5px] border-transparent bg-[color:var(--color-surface)] p-5 shadow-none transition duration-200 hover:-translate-y-[2px] hover:border-black hover:shadow-[0_18px_45px_color-mix(in_oklab,var(--color-ink)_25%,transparent)] md:flex md:items-center md:gap-6"
						href={project.data.link || withBase(`/projects/${project.id}/`)}
						target={project.data.link ? '_blank' : undefined}
						rel={project.data.link ? 'noopener noreferrer' : undefined}
					>
						<div class="flex flex-1 flex-col">
							<div class="flex items-center gap-3">
								{project.data.icon && <Icon name={project.data.icon} size={28} class="shrink-0 text-base-900" />}
								<h3 class="text-2xl font-semibold text-green-500 group-hover:text-green-500">{project.data.title}</h3>
							</div>
							{project.data.link && <p class="mt-1 text-xs text-muted">{project.data.link}</p>}
							<p class="mt-3 text-lg text-muted">{project.data.description}</p>
						</div>
						{project.data.heroImage && (
							<figure class="mt-4 h-32 w-full overflow-hidden rounded-[18px] bg-[color-mix(in_oklab,var(--color-surface)_80%,transparent)] md:mt-0 md:h-24 md:w-32">
								<Image src={project.data.heroImage} alt={project.data.title} width={220} height={140} class="h-full w-full object-cover" />
							</figure>
						)}
					</a>
				))}
			</div>
		)}
	</section>

	<div class="content-shell py-6">
		<div class="flex justify-end"><p class="text-lg px-4 py-3 rounded-2xl font-serif rounded-br-none bg-[#1d9bf0] text-white">I have no idea what I'm going to do tomorrow</p></div>
	</div>

	<section class="content-shell py-6 space-y-6">
		{friendProjects.length > 0 && (
			<>
				<h2 class="text-sm font-bold uppercase tracking-widest text-base-900">Friend Projects</h2>
				<div class="space-y-6">
					{friendProjects.map((project) => (
						<a
							class="group block w-full overflow-hidden rounded-[28px] border-[5px] border-transparent bg-[color:var(--color-surface)] p-5 shadow-none transition duration-200 hover:-translate-y-[2px] hover:border-black hover:shadow-[0_18px_45px_color-mix(in_oklab,var(--color-ink)_25%,transparent)] md:flex md:items-center md:gap-6"
							href={project.data.link || withBase(`/projects/${project.id}/`)}
							target={project.data.link ? '_blank' : undefined}
							rel={project.data.link ? 'noopener noreferrer' : undefined}
						>
							<div class="flex flex-1 flex-col">
								<div class="flex items-center gap-3">
									{project.data.icon && <Icon name={project.data.icon} size={28} class="shrink-0 text-base-900" />}
									<h3 class="text-2xl font-semibold text-green-500 group-hover:text-green-500">{project.data.title}</h3>
								</div>
								{project.data.link && <p class="mt-1 text-xs text-muted">{project.data.link}</p>}
								<p class="mt-3 text-lg text-muted">{project.data.description}</p>
							</div>
							{project.data.heroImage && (
								<figure class="mt-4 h-32 w-full overflow-hidden rounded-[18px] bg-[color-mix(in_oklab,var(--color-surface)_80%,transparent)] md:mt-0 md:h-24 md:w-32">
									<Image src={project.data.heroImage} alt={project.data.title} width={220} height={140} class="h-full w-full object-cover" />
								</figure>
							)}
						</a>
					))}
				</div>
			</>
		)}
	</section>

	<div class="content-shell py-6">
		<div class="flex justify-start"><p class="text-lg px-4 py-3 rounded-2xl font-serif rounded-bl-none bg-gray-200 text-gray-900">How exciting</p></div>
	</div>

</PageLayout>
