<script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/gsap.min.js" integrity="sha384-HOvlOYPIs/zjoIkWUGXkVmXsjr8GuZLV+Q+rcPwmJOVZVpvTSXQChiN4t9Euv9Vc" crossorigin="anonymous"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/ScrollTrigger.min.js" integrity="sha384-P8VzCVnT9NBUkMrpcIZrJbA7EBjJvh/fJS6PmP+4nLIM284DtsImIv8D0fFjIkeh" crossorigin="anonymous"></script>
<script is:inline>
/* ---------------- palette (drives card accents + hero shimmer) ---------------- */
/* Cards, hero letters, and social icons are server-rendered in the markup above;
   this script only enhances and animates the existing DOM. */
const PALETTE = ['#ef4444','#f97316','#eab308','#22c55e','#06b6d4','#3b82f6','#6366f1','#7c3aed','#a855f7'];

/* per-card accent colour for the hover color-bleed */
document.querySelectorAll('.card').forEach((card, i) => {
  card.style.setProperty('--card-accent', PALETTE[(i * 2 + 1) % PALETTE.length]);
});

/* eyebrow draw-on rule */
document.querySelectorAll('.eyebrow').forEach((h) => {
  const rule = document.createElement('span'); rule.className = 'eyebrow-rule';
  h.appendChild(rule);
});

/* ---------------- theme toggle ---------------- */
(function(){
  const root = document.documentElement, btn = document.getElementById('themeToggle');
  const SUN = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>';
  const MOON = '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z"/></svg>';
  const sync = () => { btn.innerHTML = root.getAttribute('data-theme') === 'dark' ? MOON : SUN; };
  sync();
  btn.addEventListener('click', () => {
    const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    root.setAttribute('data-theme', next);
    try { localStorage.setItem('theme-pref', next); } catch(e){}
    sync();
  });
})();

/* clicking the brand scrolls back to the top */
(function(){
  const brand = document.querySelector('.brand');
  if (!brand) return;
  const toTop = () => window.scrollTo({ top: 0, behavior: matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth' });
  brand.addEventListener('click', toTop);
  brand.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toTop(); } });
})();

/* ---------------- GSAP ---------------- */
gsap.registerPlugin(ScrollTrigger);

const mm = gsap.matchMedia();

mm.add({
  motion: '(prefers-reduced-motion: no-preference)',
  reduce: '(prefers-reduced-motion: reduce)',
  desktop: '(min-width: 760px)',
}, (ctx) => {
  const { motion, desktop } = ctx.conditions;

  /* scroll progress bar */
  gsap.to('#progress', {
    scaleX: 1, ease: 'none',
    scrollTrigger: { trigger: document.body, start: 'top top', end: 'bottom bottom', scrub: 0.3 },
  });

  if (!motion) {
    gsap.set(['.hero-letters span', '#avatar', '.social-row a', '.cta', '.bubble', '.reveal-text span', '.card'], { clearProps: 'all', opacity: 1 });
    gsap.set('.eyebrow-rule', { scaleX: 1 });
    return;
  }

  /* ---- hero scales + fades as it scrolls away (no pin, so no reserved gap) ---- */
  if (desktop) {
    gsap.fromTo('.hero',
      { scale: 1, autoAlpha: 1, y: 0 },
      { scale: 0.9, autoAlpha: 0, y: -16, ease: 'none', immediateRender: false,
        scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: true } }
    );
  }

  /* ---- eyebrow rule draw-on ---- */
  document.querySelectorAll('.eyebrow').forEach((h) => {
    const rule = h.querySelector('.eyebrow-rule');
    ScrollTrigger.create({
      trigger: h, start: 'top 86%', once: true,
      onEnter: () => { gsap.to(rule, { scaleX: 1, duration: 0.8, ease: 'power3.out' }); },
    });
  });

  /* ---- thumbnail parallax: image drifts against the card ---- */
  gsap.utils.toArray('.card-thumb img').forEach((img) => {
    const card = img.closest('.card');
    gsap.fromTo(img, { yPercent: -18 }, {
      yPercent: 4, ease: 'none',
      scrollTrigger: { trigger: card, start: 'top bottom', end: 'bottom top', scrub: true },
    });
  });

  /* ---- the social icons row scrubs up into the top bar, merging with brand + toggle ---- */
  {
    const socialRow = document.getElementById('socialRow');
    gsap.fromTo(document.documentElement,
      { '--nav-p': 0 },
      { '--nav-p': 1, ease: 'none', immediateRender: false,
        scrollTrigger: { trigger: socialRow, start: 'top top+=100', end: 'top top+=12', scrub: true } }
    );
  }

  /* ---- "Work with me" scrubs from the hero button into the nav handshake icon ---- */
  {
    const tl = gsap.timeline({
      scrollTrigger: { trigger: '.cta-wrap', start: 'top top+=120', end: 'top top+=26', scrub: true },
    });
    tl.fromTo('#cta', { autoAlpha: 1, scale: 1 }, { autoAlpha: 0, scale: 0.5, ease: 'none', immediateRender: false }, 0);
    tl.fromTo('#navCta', { scale: 0, autoAlpha: 0 }, { scale: 1, autoAlpha: 1, ease: 'none', immediateRender: false }, 0);
  }

  /* ---- "Rich Kuo" brand scrubs into the nav as the hero title scrolls away ---- */
  {
    gsap.fromTo('.brand',
      { autoAlpha: 0, x: -8 },
      { autoAlpha: 1, x: 0, ease: 'none', immediateRender: false,
        scrollTrigger: { trigger: '.hero', start: 'top top', end: '+=150', scrub: true } }
    );
  }

  /* ---- hero intro timeline ---- */
  const intro = gsap.timeline({ defaults: { ease: 'power3.out' } });
  intro
    .from('#avatar', { scale: 0, rotation: -180, autoAlpha: 0, duration: 0.9, ease: 'back.out(1.7)' })
    .from('.hero-letters span:not(.space)', {
      yPercent: 120, autoAlpha: 0, rotationX: -90, transformOrigin: '50% 100% -20px',
      duration: 0.7, stagger: 0.06, ease: 'back.out(1.8)',
    }, '-=0.5')
    .from('.social-row a', { y: 24, autoAlpha: 0, scale: 0.4, duration: 0.5, stagger: { each: 0.07, from: 'center' }, ease: 'back.out(2)' }, '-=0.35')
    .from('.cta', { y: 18, autoAlpha: 0, scale: 0.8, duration: 0.5 }, '-=0.25');

  /* continuous rainbow shimmer across hero letters */
  gsap.to('.hero-letters span:not(.space)', {
    color: (i) => PALETTE[(i + 3) % PALETTE.length],
    duration: 2.2, ease: 'sine.inOut', repeat: -1, yoyo: true,
    stagger: { each: 0.12, from: 'start', repeat: -1, yoyo: true },
  });

  /* gentle avatar float */
  gsap.to('#avatar', { y: -8, duration: 2.4, ease: 'sine.inOut', repeat: -1, yoyo: true });

  /* ---- drifting blobs ---- */
  gsap.to('.blob.a', { x: 80, y: 60, scale: 1.15, duration: 14, ease: 'sine.inOut', repeat: -1, yoyo: true });
  gsap.to('.blob.b', { x: -90, y: 40, scale: 1.2, duration: 18, ease: 'sine.inOut', repeat: -1, yoyo: true });
  gsap.to('.blob.c', { x: 60, y: -70, scale: 1.1, duration: 16, ease: 'sine.inOut', repeat: -1, yoyo: true });

  /* ---- section eyebrow wipe ---- */
  gsap.utils.toArray('.reveal-text').forEach((el) => {
    gsap.from(el.querySelector('span'), {
      yPercent: 120, autoAlpha: 0, duration: 0.7, ease: 'power3.out',
      scrollTrigger: { trigger: el, start: 'top 88%' },
    });
  });

  /* ---- chat bubbles: letter-by-letter typing ---- */
  gsap.utils.toArray('.bubble').forEach((b) => {
    const text = b.textContent;
    b.textContent = '';
    b.style.whiteSpace = 'pre-wrap';
    const chars = text.split('').map((c) => {
      const s = document.createElement('span'); s.className = 'ch'; s.textContent = c;
      b.appendChild(s); return s;
    });
    const caret = document.createElement('span'); caret.className = 'caret';
    b.appendChild(caret);
    gsap.set(chars, { autoAlpha: 0 });
    ScrollTrigger.create({
      trigger: b, start: 'top 88%', once: true,
      onEnter: () => {
        gsap.to(chars, {
          autoAlpha: 1, duration: 0.01, ease: 'none', stagger: 0.028,
          onComplete: () => gsap.to(caret, { autoAlpha: 0, duration: 0.3, delay: 0.5 }),
        });
      },
    });
  });

  /* ---- cards: alternating left/right slide-in, scroll-linked ---- */
  gsap.utils.toArray('.card').forEach((card, i) => {
    const fromLeft = i % 2 === 0;
    gsap.fromTo(card,
      { autoAlpha: 0, xPercent: fromLeft ? -120 : 120, rotationZ: fromLeft ? -3 : 3, scale: 0.92 },
      {
        autoAlpha: 1, xPercent: 0, rotationZ: 0, scale: 1, ease: 'power2.out',
        scrollTrigger: { trigger: card, start: 'top 95%', end: 'top 58%', scrub: 0.6 },
      }
    );

    if (desktop) {
      const rotX = gsap.quickTo(card, 'rotationX', { duration: 0.4, ease: 'power3' });
      const rotY = gsap.quickTo(card, 'rotationY', { duration: 0.4, ease: 'power3' });
      const liftY = gsap.quickTo(card, 'y', { duration: 0.4, ease: 'power3' });
      gsap.set(card, { transformPerspective: 800 });
      card.addEventListener('mousemove', (e) => {
        const r = card.getBoundingClientRect();
        const px = (e.clientX - r.left) / r.width - 0.5;
        const py = (e.clientY - r.top) / r.height - 0.5;
        rotY(px * 12); rotX(-py * 12); liftY(-6);
        card.style.setProperty('--mx', (e.clientX - r.left) + 'px');
        card.style.setProperty('--my', (e.clientY - r.top) + 'px');
      });
      card.addEventListener('mouseleave', () => { rotX(0); rotY(0); liftY(0); });
    }
  });

  /* ---- social icon magnetic hover ---- */
  if (desktop) {
    document.querySelectorAll('.social-row a').forEach((a) => {
      const xTo = gsap.quickTo(a, 'x', { duration: 0.4, ease: 'power3' });
      const yTo = gsap.quickTo(a, 'y', { duration: 0.4, ease: 'power3' });
      const sTo = gsap.quickTo(a, 'scale', { duration: 0.4, ease: 'power3' });
      a.addEventListener('mousemove', (e) => {
        const r = a.getBoundingClientRect();
        xTo((e.clientX - (r.left + r.width/2)) * 0.5);
        yTo((e.clientY - (r.top + r.height/2)) * 0.5);
        sTo(1.4);
      });
      a.addEventListener('mouseleave', () => { xTo(0); yTo(0); sTo(1); });
    });

    /* CTA magnetic */
    const cta = document.getElementById('cta');
    const cx = gsap.quickTo(cta, 'x', { duration: 0.4, ease: 'power3' });
    const cy = gsap.quickTo(cta, 'y', { duration: 0.4, ease: 'power3' });
    cta.addEventListener('mousemove', (e) => {
      const r = cta.getBoundingClientRect();
      cx((e.clientX - (r.left + r.width/2)) * 0.4);
      cy((e.clientY - (r.top + r.height/2)) * 0.4);
    });
    cta.addEventListener('mouseleave', () => { cx(0); cy(0); });

    /* ---- cursor glow follow ---- */
    const glow = document.getElementById('cursor-glow');
    const gx = gsap.quickTo(glow, 'x', { duration: 0.6, ease: 'power3' });
    const gy = gsap.quickTo(glow, 'y', { duration: 0.6, ease: 'power3' });
    window.addEventListener('mousemove', (e) => { gx(e.clientX); gy(e.clientY); });
    window.addEventListener('mouseenter', () => gsap.to(glow, { autoAlpha: 1, duration: 0.4 }));
    window.addEventListener('mouseleave', () => gsap.to(glow, { autoAlpha: 0, duration: 0.4 }));
  }
});
</script>
</body>
</html>
