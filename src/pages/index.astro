          <div class="card-body">
            <div class="card-title"><Fragment set:html={ICONS[p.icon]} /><span>{p.title}</span></div>
            {p.link && <p class="card-link">{p.link}</p>}
            {p.desc && <p class="card-desc">{p.desc}</p>}
          </div>
          {p.vid && (
            <div class="card-thumb">
              <img src={`https://img.youtube.com/vi/${p.vid}/mqdefault.jpg`} alt={p.title} loading="lazy" />
