const socials = [
	{ href: 'https://github.com/richkuo', label: 'GitHub', icon: 'github' },
	{ href: 'https://www.linkedin.com/in/richkuo', label: 'LinkedIn', icon: 'linkedin' },
	{ href: 'https://x.com/richkuo7', label: 'X', icon: 'x' },
	{ href: 'https://www.youtube.com/@richkuo7', label: 'YouTube', icon: 'youtube' },
	{ href: 'https://www.tiktok.com/@rich_kuo1', label: 'TikTok', icon: 'tiktok' },
	{ href: 'https://discord.gg/44BykmWZsP', label: 'Discord', icon: 'discord' },
	{ href: 'mailto:rich.kuo.ai@gmail.com', label: 'Email', icon: 'mail' },
];

type Card = { title: string; icon: string; desc?: string; link?: string; href?: string; vid?: string; img?: string };

const currentProjects: Card[] = [
	{ title: 'SceneCut AI', icon: 'video', link: 'https://www.scenecutai.com', desc: 'The best content creation app — no edits, easy reshoots, scripting, voice overs, sound effects, advanced AI video generation, and more.' },
	{ title: 'go-trader', icon: 'chart', link: 'https://github.com/richkuo/go-trader', desc: 'An OpenClaw trading bot for Discord that enables custom trading platforms and algorithms.' },
	{ title: 'VibeCode Support', icon: 'headset', link: 'https://www.officialvibecodesupport.com', desc: 'Got a vibe coded app? Stuck on a bug? Schedule a consultation today! Bugfix guaranteed!' },
];
const friendProjects: Card[] = [
	{ title: 'Art Ping Pong', icon: 'palette', link: 'https://artpingpong.valyss.com', desc: 'AI enhanced drawing fun for the entire family. Draw and share digital art together!' },
];
const videos: Card[] = [
	{ title: 'How to Build a Feature End-to-End with AI (Opus 4.8 + Cursor Tutorial)', icon: 'youtube', link: 'https://www.youtube.com/watch?v=7paxjEwckCo', vid: '7paxjEwckCo', desc: 'YouTube tutorial walking through building a complete software feature end-to-end with AI, using Claude Opus 4.8 and the Cursor IDE.' },
	{ title: 'Full OpenClaw Setup on a VPS with TailScale VPN and Maximum Firewall', icon: 'youtube', link: 'https://youtu.be/SHcTKVAdgV0', vid: 'SHcTKVAdgV0', desc: 'YouTube video walkthrough of setting up OpenClaw on a VPS with TailScale VPN and maximum firewall configuration.' },
	{ title: 'Openclaw Full Setup Part 2: Discord Bot and the UI Dashboard', icon: 'youtube', link: 'https://youtu.be/4UjAP6W06TY', vid: '4UjAP6W06TY', desc: 'YouTube video walkthrough of setting up the OpenClaw Discord bot and UI dashboard.' },
	{ title: 'OpenClaw Fully Automated Live Trading Bot on Hyperliquid - Full Setup Tutorial', icon: 'youtube', link: 'https://youtu.be/TgaKtLfxtb8', vid: 'TgaKtLfxtb8', desc: 'YouTube video walkthrough of setting up OpenClaw as an automated live trading bot on Hyperliquid.' },
	{ title: 'GPT 5.5 + OpenClaw + AI Trading Bot + Part 1 Tutorial 🦞May 2026 Update🦞', icon: 'youtube', link: 'https://www.youtube.com/watch?v=CyLjU4GEH5w', vid: 'CyLjU4GEH5w', desc: 'YouTube video walkthrough of building an AI trading bot with GPT 5.5 and OpenClaw.' },
	{ title: 'Ai Trading with Go-Trader on Hyperliquid Part 2: Hermes/OpenClaw Bots Running 24/7', icon: 'youtube', link: 'https://www.youtube.com/watch?v=n6OPc8j1GoQ', vid: 'n6OPc8j1GoQ', desc: 'YouTube video walkthrough of running Hermes and OpenClaw trading bots 24/7 with Go-Trader on Hyperliquid.' },
];
const resources: Card[] = [
	{ title: 'MiniMax Web Search MCP Server Setup for OpenClaw', icon: 'search', href: '/openclaw/minimax-websearch-mcp-setup/', desc: "Step-by-step guide to setting up MiniMax's web search MCP server with mcporter for real-time search in OpenClaw agents." },
	{ title: 'OpenClaw Kimi K2.6 Bugfix', icon: 'bug', href: '/openclaw/kimi-k2-6-bugfix/', desc: 'How to fix Kimi configuration drift in OpenClaw where sessions silently fall back to a different model instead of staying on kimi-k2.6.' },
	{ title: 'fableplan', icon: 'plan', href: '/fableplan', link: 'https://github.com/richkuo/fableplan', desc: 'Why I plan with Fable 5 and build with Opus or Sonnet: a Claude Code skill that delegates implementation planning to a Fable 5 subagent, then builds from the vetted plan in an isolated git worktree.' },
];
const llmBattles: Card[] = [
	{ title: 'Bake-off Ep.1 — The First Feature', icon: 'trophy', href: '/reports/issue-844/index.html', img: '/reports/issue-844/og-ai-model-bakeoff.png', desc: 'Four models each build the same trading-bot feature from one spec, scored on cost, speed, review rounds, and code quality. Winner: GPT-5.' },
	{ title: 'Bake-off Ep.2 — Scale-In', icon: 'trophy', href: '/reports/issue-873/index.html', img: '/reports/issue-873/og-scale-in-bakeoff.png', desc: 'Three models add to an open position without breaking its original risk plan. Winner: Opus 4.8 — speed and cost ran exactly backwards to correctness.' },
	{ title: 'Bake-off Ep.3 — The Regime Refactor', icon: 'trophy', href: '/reports/issue-879/index.html', img: '/reports/issue-879/og-regime-bakeoff.png', desc: 'Six AI runs across five models refactor a live-trading market-regime calc into one shared source of truth. Winner: Fable 5 — and the fastest run shipped a silent production crash.' },
	{ title: 'Bake-off Ep.4 — The Audit', icon: 'trophy', href: '/reports/issue-906/index.html', img: '/reports/issue-906/og-backtest-audit-bakeoff.png', desc: 'Three models audit a live trading bot\'s backtesting engine and build the one tool that catches backtest-vs-live drift before it ships. Winner: Fable 5 — it shipped a third of the runner-up\'s code, touched no production files, and still won.' },
	{ title: 'Bake-off Ep.5 — Welcome GLM', icon: 'trophy', href: '/reports/issue-1124/index.html', img: '/reports/issue-1124/og-ranging-directional-bakeoff.png', desc: 'Three models take the same safety-critical market-regime label split. Co-winners: Opus 4.8 and GLM 5.2, tied at 96 — one wrote a fifth of the other\'s code, and the fastest model came last.' },
	{ title: 'Bake-off Ep.6 — Welcome Composer', icon: 'trophy', href: '/reports/issue-1134/index.html', img: '/reports/issue-1134/og-regime-atr-bakeoff.png', desc: 'Four models add one operator settings knob to a live trading bot without silently switching off a real-money safety net. Co-winners: GPT-5.5 and GLM 5.2, tied at 94 — the model that wrote the most code tied for first, and the fastest model came last.' },
];

const sameAs = socials.filter((s) => s.href.startsWith('http')).map((s) => s.href);

const personJsonLd = {
	'@type': 'Person',
	'@id': `${SITE_URL}/#person`,
	name: 'Rich Kuo',
	url: `${SITE_URL}/`,
	image: profileURL,
	jobTitle: 'Product Engineer',
	description: site.author?.bio ?? site.description,
	knowsAbout: site.author?.knowsAbout ?? [],
	sameAs,
};

const websiteJsonLd = {
	'@type': 'WebSite',
	'@id': `${SITE_URL}/#website`,
	name: 'Rich Kuo',
	url: `${SITE_URL}/`,
	description: site.description,
	inLanguage: 'en-US',
	publisher: { '@id': `${SITE_URL}/#person` },
};

const profilePageJsonLd = {
	'@type': 'ProfilePage',
	'@id': `${SITE_URL}/#profilepage`,
	url: `${SITE_URL}/`,
	name: 'Rich Kuo — Product Engineer',
	isPartOf: { '@id': `${SITE_URL}/#website` },
	about: { '@id': `${SITE_URL}/#person` },
	mainEntity: { '@id': `${SITE_URL}/#person` },
	inLanguage: 'en-US',
};

// Enumerate the LLM Battles series so answer/generative engines can list the
// full set of bake-offs and cite the individual reports.
const llmBattlesItemList = {
	'@type': 'ItemList',
	'@id': `${SITE_URL}/#llm-battles`,
	name: 'LLM Battles — AI coding bake-offs',
	description:
		'Head-to-head bake-offs scoring frontier AI models (GPT, Claude Opus, GLM, Fable, Composer) on identical real-world coding tasks — cost, speed, review rounds, and code quality.',
	itemListOrder: 'https://schema.org/ItemListOrderAscending',
	numberOfItems: llmBattles.length,
	itemListElement: llmBattles.map((b, i) => ({
		'@type': 'ListItem',
		position: i + 1,
		name: b.title,
		url: `${SITE_URL}${(b.href ?? '').replace(/index\.html$/, '')}`,
	})),
};

const graphJsonLd = {
	'@context': 'https://schema.org',
	'@graph': [personJsonLd, websiteJsonLd, profilePageJsonLd, llmBattlesItemList],
};
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{pageTitle}</title>
<meta name="description" content={metaDescription} />
<meta name="author" content="Rich Kuo" />
<link rel="canonical" href="https://www.richkuo.com/" />
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
<meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0d0d10" />
<meta name="theme-color" media="(prefers-color-scheme: light)" content="#ffffff" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" title="Rich Kuo" href="https://www.richkuo.com/rss.xml" />
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Rich Kuo" />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={metaDescription} />
<meta property="og:url" content="https://www.richkuo.com/" />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="Rich Kuo — Product Engineer" />
<meta property="og:locale" content="en_US" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@richkuo7" />
<meta name="twitter:creator" content="@richkuo7" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={metaDescription} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content="Rich Kuo — Product Engineer" />
<script type="application/ld+json" set:html={JSON.stringify(graphJsonLd)} />

<script is:inline>
  /* set theme before paint to avoid a flash */
  (function(){
    try {
      var p = localStorage.getItem('theme-pref');
      var dark = p ? p === 'dark' : matchMedia('(prefers-color-scheme: dark)').matches;
      document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light');
    } catch(e){}
  })();
</script>

<style is:global>
  :root {
    --font-sans: ui-sans-serif, system-ui, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji";
    --font-serif: ui-serif, Georgia, Cambria, "Times New Roman", Times, serif;
    --nav-p: 0; /* 0 = hero row, 1 = docked nav (scrubbed by scroll) */
    --ink: #0a0a0a;
    --muted: color-mix(in oklab, var(--ink) 64%, transparent);
    --paper: #ffffff;
    --surface: #ffffff;
    --border: color-mix(in oklab, var(--ink) 12%, transparent);
    --card-shadow: 0 18px 45px color-mix(in oklab, var(--ink) 22%, transparent);
    --accent: #22c55e;
    --title-color: #22c55e;
    --bubble-them: #e9eaed;
    --bubble-them-ink: #111;
    --blob-a: #3b82f6;
    --blob-b: #06b6d4;
    --blob-c: #2dd4bf;
  }
  :root[data-theme="dark"] {
    --ink: #f5f5f5;
    --title-color: #fbbf24;
    --muted: color-mix(in oklab, var(--ink) 62%, transparent);
    --paper: #0d0d10;
    --surface: #15151b;
    --border: color-mix(in oklab, var(--ink) 16%, transparent);
    --card-shadow: 0 18px 55px rgba(0,0,0,0.6);
    --bubble-them: #26262e;
    --bubble-them-ink: #f0f0f0;
    --blob-a: #2563eb;
    --blob-b: #0e7490;
    --blob-c: #0d9488;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    margin: 0;
    font-family: var(--font-sans);
    color: var(--ink);
    background: var(--paper);
    line-height: 1.6;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
  }
  a { color: inherit; text-decoration: none; }

  /* ---- drifting gradient blobs ---- */
  .blob-field {
    position: fixed; inset: 0; z-index: 0; overflow: hidden;
    pointer-events: none; filter: blur(70px); opacity: 0.5;
  }
  :root[data-theme="dark"] .blob-field { opacity: 0.42; }
  .blob {
    position: absolute; width: 46vw; height: 46vw; border-radius: 50%;
    mix-blend-mode: normal; will-change: transform;
  }
  .blob.a { background: var(--blob-a); top: -8vw; left: -6vw; }
  .blob.b { background: var(--blob-b); top: 32vh; right: -10vw; width: 40vw; height: 40vw; }
  .blob.c { background: var(--blob-c); bottom: -14vw; left: 24vw; width: 38vw; height: 38vw; }

  /* ---- scroll progress ---- */
  #progress {
    position: fixed; top: 0; left: 0; height: 3px; width: 100%;
    transform: scaleX(0); transform-origin: 0 50%; z-index: 50;
    background: linear-gradient(90deg,#ef4444,#f97316,#eab308,#22c55e,#06b6d4,#3b82f6,#6366f1,#a855f7);
  }

  /* ---- custom cursor glow (desktop) ---- */
  #cursor-glow {
    position: fixed; top: 0; left: 0; width: 380px; height: 380px;
    margin: -190px 0 0 -190px; border-radius: 50%; z-index: 1; pointer-events: none;
    background: radial-gradient(circle, color-mix(in oklab, var(--accent) 26%, transparent), transparent 62%);
    opacity: 0; will-change: transform; mix-blend-mode: normal;
  }

  .shell { position: relative; z-index: 2; max-width: 720px; margin: 0 auto; padding: 0 20px; }

  /* ---- top bar ---- */
  .topbar {
    position: sticky; top: 12px; z-index: 41;
    /* full content width at the top, shrinks to a 560px capsule as it docks */
    width: 100%; max-width: calc(720px - var(--nav-p) * 160px); margin: 0 auto;
    display: flex; align-items: center; gap: 14px;
    height: 54px; padding: 0 calc(var(--nav-p) * 18px);
    /* iOS-26-style floating glass capsule, scrubbed in as the bar docks */
    background: color-mix(in oklab, var(--paper) calc(var(--nav-p) * 18%), transparent);
    backdrop-filter: blur(calc(var(--nav-p) * 8px)) saturate(calc(100% + var(--nav-p) * 45%));
    -webkit-backdrop-filter: blur(calc(var(--nav-p) * 8px)) saturate(calc(100% + var(--nav-p) * 45%));
    border-radius: 27px;
    border: 1px solid color-mix(in oklab, white calc(var(--nav-p) * 24%), transparent);
    box-shadow:
      inset 0 1px 1px 0 rgba(255, 255, 255, calc(var(--nav-p) * 0.45)),
      0 calc(var(--nav-p) * 10px) calc(var(--nav-p) * 30px) rgba(0, 0, 0, calc(var(--nav-p) * 0.16));
  }
  .topbar .nav-cta { margin-left: auto; }
  .nav-cta {
    display: inline-flex; align-items: center; justify-content: center;
    width: 38px; height: 38px; border-radius: 999px; color: var(--ink); flex-shrink: 0;
    opacity: 0; /* hidden until the hero "Work with me" scrubs into it */
  }
  .nav-cta svg { width: 22px; height: 22px; transition: transform .2s ease; }
  .nav-cta:hover svg { transform: scale(1.12) rotate(-8deg); }
  .brand { font-weight: 700; letter-spacing: 0.02em; font-size: 1rem; opacity: 0; cursor: pointer; /* hidden until the hero title scrubs into it */ }
  .theme-toggle {
    display: inline-flex; align-items: center; justify-content: center;
    width: 38px; height: 38px; padding: 0; border: 0; border-radius: 999px;
    background: transparent; cursor: pointer; color: var(--ink); flex-shrink: 0;
  }
  .theme-toggle svg { width: 22px; height: 22px; transition: transform .2s ease; }
  .theme-toggle:hover svg { transform: scale(1.12) rotate(12deg); }

  /* ---- hero ---- */
  .hero { display: flex; align-items: center; gap: 22px; padding: 24px 0 18px; }
  .avatar {
    width: 88px; height: 88px; border-radius: 50%; object-fit: cover; flex-shrink: 0;
    background: linear-gradient(135deg,#6366f1,#06b6d4); will-change: transform;
    box-shadow: 0 10px 30px color-mix(in oklab, var(--ink) 25%, transparent);
  }
  @media (min-width: 768px){ .avatar { width: 128px; height: 128px; } }
  .hero-right { flex: 1; min-width: 0; }
  .hero-letters {
    font-weight: 800;
    font-size: clamp(2.6rem, 12vw, 5rem); line-height: 0.85; letter-spacing: -0.01em;
    display: flex; flex-wrap: wrap;
  }
  .hero-letters span { display: inline-block; will-change: transform, opacity; transform-origin: 50% 100%; }
  .hero-letters .space { width: 0.28em; }

  /* The real social row is overlaid on the top bar and scrubs from the full-width
     hero row (nav-p 0) into a centred cluster between brand + toggle (nav-p 1). */
  .social-row {
    display: flex; align-items: center; justify-content: space-between; gap: 8px;
    width: 100%; max-width: calc(100% - var(--nav-p) * 400px); margin: 0 auto;
    padding-block: 14px;
  }
  @media (prefers-reduced-motion: no-preference) {
    .social-row { position: sticky; top: 12px; z-index: 42; }
  }
  .social-row a { display: inline-flex; will-change: transform; color: var(--ink); }
  .social-row svg {
    width: calc(38px - var(--nav-p) * 14px); height: calc(38px - var(--nav-p) * 14px);
  }
  @media (min-width: 768px) {
    .social-row svg { width: calc(46px - var(--nav-p) * 20px); height: calc(46px - var(--nav-p) * 20px); }
  }

  .divider { height: 1px; background: var(--border); }

  /* ---- work with me CTA ---- */
  .cta-wrap { display: flex; justify-content: center; padding: 26px 0 10px; }
  .cta {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 9px 20px; border-radius: 14px; border: 3px solid var(--ink);
    background: var(--surface); color: var(--ink); font-weight: 700; font-size: 1rem;
    cursor: pointer; will-change: transform;
  }
  .cta svg { width: 20px; height: 20px; }

  /* ---- chat bubbles ---- */
  .bubble-row { display: flex; padding: 14px 0; }
  .bubble-row.them { justify-content: flex-start; }
  .bubble-row.me { justify-content: flex-end; }
  .bubble {
    font-family: var(--font-serif); font-size: 1.15rem; line-height: 1.4;
    padding: 12px 18px; border-radius: 20px; max-width: 78%; will-change: transform, opacity;
  }
  .bubble.them { background: var(--bubble-them); color: var(--bubble-them-ink); border-bottom-left-radius: 4px; }
  .bubble.me { background: #1d9bf0; color: #fff; border-bottom-right-radius: 4px; }
  .bubble .ch { display: inline; }
  .bubble .caret {
    display: inline-block; width: 2px; height: 1em; margin-left: 2px;
    vertical-align: -2px; background: currentColor;
    animation: blink 1s steps(1) infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }

  /* ---- section ---- */
  .eyebrow {
    display: flex; align-items: center; gap: 12px;
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--ink); margin: 30px 0 16px; overflow: hidden;
  }
  .eyebrow > span { display: inline-block; will-change: transform; }
  .eyebrow-rule {
    flex: 1; height: 2px; transform: scaleX(0); transform-origin: left center;
    background: linear-gradient(90deg, color-mix(in oklab, var(--ink) 32%, transparent), transparent);
  }

  /* ---- cards ---- */
  .card {
    position: relative; display: flex; gap: 18px; align-items: center;
    padding: 20px; border-radius: 26px;
    border: 1px solid color-mix(in oklab, var(--ink) 9%, transparent);
    background: color-mix(in oklab, var(--surface) 68%, transparent);
    backdrop-filter: blur(16px) saturate(150%); -webkit-backdrop-filter: blur(16px) saturate(150%);
    margin-bottom: 18px; cursor: pointer; will-change: transform;
    box-shadow: inset 0 1px 0 0 color-mix(in oklab, white 24%, transparent);
    transition: border-color 200ms ease, box-shadow 200ms ease;
  }
  .card::before {
    content: ""; position: absolute; inset: 0; border-radius: 26px; padding: 2px; z-index: 2;
    background: linear-gradient(120deg,#6366f1,#06b6d4,#a855f7);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor; mask-composite: exclude;
    opacity: 0; transition: opacity 220ms ease; pointer-events: none;
  }
  /* color-bleed: faint accent tint that follows the cursor */
  .card::after {
    content: ""; position: absolute; inset: 0; border-radius: 26px; z-index: 0; pointer-events: none;
    background: radial-gradient(240px circle at var(--mx, 50%) var(--my, 50%),
      color-mix(in oklab, var(--card-accent, #6366f1) 22%, transparent), transparent 62%);
    opacity: 0; transition: opacity 260ms ease;
  }
  .card:hover { box-shadow: inset 0 1px 0 0 color-mix(in oklab, white 24%, transparent), var(--card-shadow); }
  .card:hover::before { opacity: 1; }
  .card:hover::after { opacity: 1; }
  .card-body { flex: 1; min-width: 0; position: relative; z-index: 1; }
  .card-title {
    display: flex; align-items: center; gap: 10px;
    font-weight: 600; font-size: 1.5rem; color: var(--title-color);
  }
  .card-title svg { width: 26px; height: 26px; flex-shrink: 0; color: var(--ink); }
  .card-link { font-size: 0.72rem; color: var(--muted); margin: 4px 0 0; word-break: break-all; }
  .card-desc { font-size: 1.02rem; color: var(--muted); margin: 8px 0 0; }
  .card-thumb {
    width: 120px; height: 102px; border-radius: 16px; object-fit: cover; flex-shrink: 0;
    position: relative; z-index: 1; overflow: hidden;
    background: color-mix(in oklab, var(--ink) 8%, transparent);
  }
  .card-thumb img { width: 100%; height: 130%; object-fit: cover; will-change: transform; }
  @media (max-width: 560px){
    .card { flex-direction: column; align-items: stretch; }
    .card-thumb { width: 100%; height: 150px; }
  }

  footer {
    position: relative; z-index: 2; text-align: center; color: var(--muted);
    font-size: 0.8rem; padding: 50px 20px 40px;
  }
  footer .pill {
    display:inline-block; margin-top:10px; padding:4px 12px; border:1px solid var(--border);
    border-radius:999px; font-size:0.7rem; letter-spacing:0.1em; text-transform:uppercase;
  }

  @media (prefers-reduced-motion: reduce) {
    #cursor-glow, .blob-field { display: none; }
    html { scroll-behavior: auto; }
  }
</style>
</head>
