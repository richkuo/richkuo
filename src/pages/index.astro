        </a>
      );
    })}
  </div>

  <div class="bubble-row them"><div class="bubble them">How exciting</div></div>

  <!-- LLM BATTLES -->
  <h2 class="eyebrow reveal-text"><span>LLM Battles</span></h2>
  <div id="llmBattles">
    {llmBattles.map((p) => {
      const href = p.href ?? p.link ?? '#';
      const external = /^https?:/.test(href);
      return (
        <a class="card" href={href} target={external ? '_blank' : undefined} rel={external ? 'noopener noreferrer' : undefined}>
          <div class="card-body">
            <div class="card-title"><Fragment set:html={ICONS[p.icon]} /><span>{p.title}</span></div>
            {p.desc && <p class="card-desc">{p.desc}</p>}
          </div>
          {p.img && (
            <div class="card-thumb">
