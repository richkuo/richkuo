---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Prose from '../components/Prose.astro';
import { slugify, withBase } from '../utils/slugify';

interface FaqItem { question: string; answer: string }
interface HowTo {
	name?: string;
	supply?: string[];
	tool?: string[];
	steps: { name: string; text: string }[];
}

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	heroImage?: ImageMetadata;
	ogImage?: string;
	Content?: any;
	tags?: string[];
	unlisted?: boolean;
	link?: string;
	faq?: FaqItem[];
	howTo?: HowTo;
}

const { title, description, pubDate, updatedDate, heroImage, ogImage, tags = [], unlisted = false, link, faq = [], howTo, Content } = Astro.props as Props;

const videoId = link?.match(/(?:youtu\.be\/|[?&]v=|\/embed\/)([\w-]{11})/)?.[1];

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// FAQPage / HowTo structured data — lets answer engines lift a direct,
// attributable answer straight from the page.
const faqJsonLd =
	faq.length > 0
		? {
				'@context': 'https://schema.org',
				'@type': 'FAQPage',
				url: canonicalURL.toString(),
				mainEntity: faq.map((f) => ({
					'@type': 'Question',
					name: f.question,
					acceptedAnswer: { '@type': 'Answer', text: f.answer },
				})),
			}
		: null;

const howToJsonLd = howTo
	? {
			'@context': 'https://schema.org',
			'@type': 'HowTo',
			name: howTo.name ?? title,
			description,
			...(howTo.supply?.length ? { supply: howTo.supply.map((s) => ({ '@type': 'HowToSupply', name: s })) } : {}),
			...(howTo.tool?.length ? { tool: howTo.tool.map((t) => ({ '@type': 'HowToTool', name: t })) } : {}),
			step: howTo.steps.map((s, i) => ({
				'@type': 'HowToStep',
				position: i + 1,
				name: s.name,
				text: s.text,
				url: `${canonicalURL.toString()}#step-${i + 1}`,
			})),
		}
	: null;
---

<BaseLayout title={title} description={description} image={heroImage} ogImage={ogImage} type="article" pubDate={pubDate} updatedDate={updatedDate} tags={tags} noindex={unlisted} videoUrl={videoId ? link : undefined}>
	<div class="flex-1 flex flex-col py-12 md:py-16 lg:py-20 space-y-16 min-w-0">
	<article class="post-page content-shell">
		<header class="section-heading">
			<h1>{title}</h1>
			{tags.length > 0 && (
				<ul class="mt-2 flex flex-wrap gap-2 text-sm text-muted">
					{tags.map((tag) => (
						<li class="inline-flex items-center gap-2 rounded-full border border-border bg-surface px-3 py-1">
							<a class="hover:text-ink" href={withBase(`/tags/${slugify(tag)}/`)}>{tag}</a>
						</li>
					))}
				</ul>
			)}
		</header>

		{heroImage && (
			<figure class="post-hero-image">
				<Image width={1020} height={510} src={heroImage} alt={title} />
			</figure>
		)}

		{videoId && (
			<figure class="post-hero-image aspect-video w-full overflow-hidden rounded-2xl border border-border">
				<iframe
					class="w-full h-full"
					src={`https://www.youtube-nocookie.com/embed/${videoId}`}
					title={title}
					loading="lazy"
					allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
					allowfullscreen
				></iframe>
			</figure>
		)}

		<section class="post-article">
			<Prose>
				{videoId && <p>{description}</p>}
				{Content ? <Content /> : <slot />}
			</Prose>
			<div class="mt-6 flex justify-center">
				<button
					id="copy-text-btn"
					class="inline-flex items-center justify-center gap-3 text-base text-muted hover:text-ink transition-colors cursor-pointer px-8 py-3 w-64 rounded-lg border border-border hover:border-ink"
					aria-label="Copy page text to clipboard"
				>
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
						<path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
					</svg>
					<span id="copy-text-label">Copy text</span>
				</button>
			</div>
		</section>

		{faq.length > 0 && (
			<section class="post-faq mt-16 border-t border-border pt-10" aria-labelledby="faq-heading">
				<h2 id="faq-heading" class="text-2xl font-semibold text-ink">Frequently asked questions</h2>
				<dl class="mt-6 space-y-6">
					{faq.map((f) => (
						<div>
							<dt class="text-lg font-semibold text-ink">{f.question}</dt>
							<dd class="mt-2 text-muted">{f.answer}</dd>
						</div>
					))}
				</dl>
			</section>
		)}
	</article>
	</div>

	{faqJsonLd && <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />}
	{howToJsonLd && <script type="application/ld+json" set:html={JSON.stringify(howToJsonLd)} />}

<script>
	const btn = document.getElementById('copy-text-btn');
	const label = document.getElementById('copy-text-label');

	btn?.addEventListener('click', async () => {
		const prose = document.querySelector('.prose');
		if (!prose || !label) return;

		await navigator.clipboard.writeText((prose as HTMLElement).innerText);

		label.textContent = 'Copied!';
		setTimeout(() => { label.textContent = 'Copy text'; }, 2000);
	});
</script>
</BaseLayout>
